{
    "model_name": "company-assistant",
    "base_model": "gemma3:4b",
    "training_directory": "training",
    "paths": {
        "prompts": "prompts",
        "datasets": "datasets",
        "configs": "configs"
    },
    "parameters": {
        "temperature": 0.7,
        "top_p": 0.9,
        "num_ctx": 8192,
        "stop": [
            "User:",
            "Assistant:"
        ]
    },
    "training_options": {
        "include_knowledge_base": true,
        "data_sources": [
            "processed/compressed_kb.md",
            "processed/extracted_dates.md"
        ],
        "prompt_order": [
            "persona.txt",
            "examples.txt",
            "language.txt",
            "safety.txt",
            "hallucination.txt"
        ]
    }
}